Options -MultiViews -Indexes

RewriteEngine On

# Canonical host + HTTPS (single rule to avoid double redirects)
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://stackwerkhaus.de%{REQUEST_URI} [L,R=301]

# /index.html -> /
RewriteRule ^index\.html$ / [L,R=301]

# Strip trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)/$ /$1 [L,R=301]

# Extensionless URLs -> .html
# Directory exists but has no index.html, serve the .html file instead
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# File doesn't exist, try .html extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Custom 404
ErrorDocument 404 /404.html
